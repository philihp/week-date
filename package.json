{
  "name": "week-date",
  "version": "0.0.0",
  "description": "Parses ISO-week dates strings (e.g. 2020-W09-6) into timestamps",
  "scripts": {
    "build": "node build.mjs",
    "prepublishOnly": "node build.mjs",
    "lint": "eslint .",
    "test": "node --test",
    "test:watch": "node --test --watch",
    "test:coverage": "node --test --experimental-test-coverage"
  },
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/philihp/week-date.git"
  },
  "keywords": [
    "iso",
    "iso8601",
    "week-date",
    "date"
  ],
  "author": "Philihp Busby <philihp@gmail.com>",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "bugs": {
    "url": "https://github.com/philihp/week-date/issues"
  },
  "homepage": "https://github.com/philihp/week-date#readme",
  "devDependencies": {
    "@philihp/eslint-config": "6.1.0",
    "prettier": "3.8.3"
  },
  "eslintConfig": {
    "extends": [
      "@philihp"
    ]
  }
}
